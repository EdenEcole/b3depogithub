pipeline {
    agent any

    stages {
        stage('Mise à jour système') {
            steps {
                sh 'sudo apt update'
                sh 'sudo apt install -y apt-transport-https ca-certificates curl software-properties-common'
            }
        }

        stage('Installation Docker') {
            steps {
                sh 'sudo apt install -y docker.io'
                sh 'sudo chmod 666 /var/run/docker.sock'
                sh 'sudo usermod -aG docker $USER'
            }
        }

        stage('Vérification Docker') {
            steps {
                sh 'sudo systemctl status docker.service'
                sh 'docker network ls'
                sh 'docker image ls'
            }
        }

        stage('Mise à jour des paquets') {
            steps {
                sh 'sudo apt list --upgradable'
                sh 'sudo apt upgrade -y'
            }
        }
              stage('Pull image Nginx') {
            steps {
                sh 'sudo docker pull nginx'
            }

        }
    }
}
